{
    "name": "mykolapodpriatov/example_starter",
    "description": "Production-ready starter template for custom Drupal 10/11 modules. Demonstrates DI, services, config schema, plugins, events, and full test coverage.",
    "type": "drupal-module",
    "license": "MIT",
    "keywords": [
        "Drupal",
        "drupal-module",
        "boilerplate",
        "template",
        "starter"
    ],
    "homepage": "https://github.com/mykolapodpriatov/drupal-module-boilerplate",
    "authors": [
        {
            "name": "Mykola Podpriatov",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/mykolapodpriatov/drupal-module-boilerplate/issues",
        "source": "https://github.com/mykolapodpriatov/drupal-module-boilerplate"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "drupal/core": "^10.3 || ^11"
    },
    "require-dev": {
        "drupal/coder": "^8.3",
        "mglaman/phpstan-drupal": "^1.2 || ^2",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^1.10 || ^2",
        "phpstan/phpstan-deprecation-rules": "^1.1 || ^2",
        "phpstan/phpstan-phpunit": "^1.3 || ^2",
        "phpunit/phpunit": "^9.6 || ^10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml.dist src tests",
        "lint:fix": "phpcbf --standard=phpcs.xml.dist src tests",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:kernel": "phpunit --testsuite=kernel",
        "test:functional": "phpunit --testsuite=functional"
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        }
    }
}
